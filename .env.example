# CMS — obavezno promeniti u produkciji
CMS_PASSWORD=your-secure-password
CMS_SECRET=your-random-secret-key-min-32-chars

# Vercel Blob — za čuvanje CMS podataka na produkciji
# Kreiraj Blob store u Vercel dashboardu → Storage → Blob
BLOB_READ_WRITE_TOKEN=

# Postojeće (cron za osvežavanje cena)
CRON_SECRET=

# Email porudžbine — SMTP (mail hosting prodaja@bojleri.com)
SMTP_HOST=mail.bojleri.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=prodaja@bojleri.com
SMTP_PASS=
ORDER_FROM_EMAIL=bojleri.com <prodaja@bojleri.com>
ORDER_NOTIFY_EMAIL=prodaja@bojleri.com

# Alternativa: Resend (https://resend.com) — koristi se samo ako SMTP nije podešen
RESEND_API_KEY=

# Alternativa: Web3Forms — samo obaveštenje prodavcu, bez potvrde kupcu
WEB3FORMS_ACCESS_KEY=