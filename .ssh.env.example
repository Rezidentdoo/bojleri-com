# SSH pristup za bojleri.com (unlimited.rs)
# Kopiraj: cp .ssh.env.example .ssh.env
# Popuni lozinku ili putanju do SSH ključa — fajl NE ide u git.

SSH_HOST=s60.unlimited.rs
SSH_USER=aqualand
# unlimited.rs: SSH shell = 9780, SFTP = 9790 (v. KB na panel.unlimited.rs)
SSH_PORT=9780
SSH_REMOTE_DIR=/home/aqualand/bojleri.com/web

# Opcija A: lozinka (za sshpass, ako je instaliran)
SSH_PASS=

# Opcija B: SSH ključ (preporučeno)
# SSH_KEY=/home/rezident/.ssh/bojleri_id_rsa